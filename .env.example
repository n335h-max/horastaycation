VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
VITE_MANAGEMENT_EMAILS=owner@example.com,admin@example.com
VITE_PRIVACY_CONTACT_EMAIL=privacy@horastaycation.com
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_CURRENCY=usd

# Management uploads require the SQL in supabase/schema.sql
# to create the management_listings table and public storage buckets.
# Production deployments should stay behind HTTPS only.
# Use a TLS-enabled Supabase project so customer data stays encrypted in transit.
# Keep Stripe secret keys on the server only. Never expose them in frontend code.

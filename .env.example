VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
VITE_MANAGEMENT_EMAILS=owner@example.com,admin@example.com
VITE_PRIVACY_CONTACT_EMAIL=privacy@horastaycation.com
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_CURRENCY=usd
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
APP_BASE_URL=https://your-domain.com
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Management uploads require the SQL in supabase/schema.sql
# to create the management_listings table and public storage buckets.
# Production deployments should stay behind HTTPS only.
# Use a TLS-enabled Supabase project so customer data stays encrypted in transit.
# Keep Stripe secret keys on the server only. Never expose them in frontend code.
# For local development, create a top-level `.env` (or `.env.local`) file and
# set your real keys there. Never commit files that contain `STRIPE_SECRET_KEY`.
# Example (local only):
#   VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
#   STRIPE_SECRET_KEY=sk_live_...
#   STRIPE_WEBHOOK_SECRET=whsec_...
# If these keys are ever shared publicly (e.g. posted in chat or committed),
# rotate them immediately via the Stripe Dashboard and update your deployment
# environment variables. Do not paste secret keys into issue trackers or chats.

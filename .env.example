# Environment Variables Reference
# ──────────────────────────────────────────────────────────────
# Copy this file to `.env` or `.env.local` for local development.
# For production, configure these in the Vercel dashboard:
#   https://vercel.com/n33shs-projects/horastaycation/settings/environment-variables
#
# ⚠️  NEVER commit files that contain real secret keys.
#     If a key is ever exposed, rotate it immediately via the
#     Stripe / Supabase / Resend dashboard and update Vercel.
# ──────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Stripe ────────────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_CURRENCY=usd
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Resend (Email) ────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
MANAGEMENT_EMAIL=admin@yourdomain.com

# ── Application ────────────────────────────────────────────────
# Management login is restricted to ONLY these emails (client allowlist).
# Must match the management_users rows seeded in Supabase (server-side gate).
VITE_MANAGEMENT_EMAILS=admin@example.com,manager@example.com
VITE_PRIVACY_CONTACT_EMAIL=privacy@horastaycation.com
VITE_WHATSAPP_SUPPORT=601110629990
APP_BASE_URL=https://your-domain.com
